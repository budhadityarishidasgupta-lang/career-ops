# career-ops environment variables
# Copy to .env and fill in real values. NEVER commit .env.

# ── LLM providers ──────────────────────────────────────────────────────────

# Anthropic (Claude) — required for evaluations and cover letters via claude CLI
ANTHROPIC_API_KEY=sk-ant-...

# Kimi (Moonshot AI) — optional: used when --model=kimi or CAREER_OPS_MODEL=kimi
# Get key at: https://platform.moonshot.cn
KIMI_API_KEY=sk-kimi-...
KIMI_BASE_URL=https://api.moonshot.cn/v1

# OpenRouter — optional: unified API for 200+ models (Claude, GPT-4, Llama, etc.)
# Get key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...

# Gemini (Google) — optional: used by `npm run eval:gemini` (free tier 15 RPM)
# Get key at: https://aistudio.google.com
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash

# Model selection: 'claude' | 'claude-opus' | 'claude-haiku' | 'kimi' | 'openrouter:MODEL_ID'
# Can also be set per-run with --model flag (e.g., --model kimi, --model openrouter:gpt-4o)
# CAREER_OPS_MODEL=claude

# Ollama / Gemma — optional local model
# OLLAMA_BASE_URL=http://localhost:11434
# GEMMA_MODEL=gemma4:latest

# ── Notifications ──────────────────────────────────────────────────────────

# Gmail SMTP — for outbound email notifications when high-scoring jobs are found
# Use a Gmail App Password (not your main password):
#   1. Enable 2FA on your Google account
#   2. Go to myaccount.google.com/apppasswords → create "career-ops" app
#   3. Paste the 16-char app password below (no spaces)
GMAIL_USER=you@example.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
NOTIFY_EMAIL=you@example.com

# ── Gmail OAuth (inbox monitoring) ─────────────────────────────────────────

# Required for inbox monitoring and verification code extraction
# Get credentials at: https://console.cloud.google.com (Gmail API → OAuth 2.0)
# Redirect URI must match exactly: http://localhost:4747/auth/gmail/callback
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REDIRECT_URI=http://localhost:4747/auth/gmail/callback

# ── Server runtime (optional — defaults shown) ─────────────────────────────

# PORT=4747
# HOST=127.0.0.1
# CONFIG_DIR=./config        # where profile.yml lives
# DATA_DIR=./data            # tracker, pipeline, scan-history
# REPORTS_DIR=./reports      # evaluation reports

# Cross-origin allowlist for the dashboard's POST endpoints (CSRF defense).
# Defaults to same-origin (localhost:PORT). Override when running behind a
# reverse proxy or a public domain. Comma-separated.
# ALLOWED_ORIGIN=https://career.example.com

# Auto-start the autopilot (auto-apply) loop on server boot. Off by default —
# autopilot opens a real browser and applies to jobs without further consent,
# so it requires an explicit opt-in.
# AUTOPILOT_AUTOSTART=1

# Auto-start the pipeline (scan → evaluate → cover letter → CV) loop on boot.
# Off by default for the same reason.
# PIPELINE_AUTOSTART=1

# Override Playwright's bundled Chromium with a system browser (Chrome /
# Chromium / Edge). Useful when bundled Chromium fails to launch.
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

# ── Obsidian (optional) ────────────────────────────────────────────────────

# Obsidian vault path (host machine path)
# Docker scheduler uses /obsidian-vault (mounted in docker-compose.yaml)
# On host: set this to your actual vault path if different
# OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# ── Claude-Code-Free Autopilot ─────────────────────────────────────────────

# With ANTHROPIC_API_KEY set, run full autopilot without Claude Code:
#   node jobseeker.mjs --loop --model claude
# With KIMI_API_KEY set:
#   node jobseeker.mjs --loop --model kimi
# With OPENROUTER_API_KEY set:
#   node jobseeker.mjs --loop --model openrouter:anthropic/claude-sonnet-4
